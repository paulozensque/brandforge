# Database (Neon free tier: https://neon.tech)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-secret-here"

# Google OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# AI - Use OpenAI for production (Ollama for local dev)
OPENAI_API_KEY="sk-your-key"
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL="gpt-4o-mini"

# OpenAI for image generation (DALL-E 3)
OPENAI_IMAGE_KEY="sk-your-key"

# App
NEXT_PUBLIC_APP_NAME="ECO by ZEN POWER"
NEXT_PUBLIC_APP_URL="https://your-domain.vercel.app"

# Evolution API (WhatsApp) - optional for production
EVOLUTION_API_URL="http://localhost:8080"
EVOLUTION_API_KEY="your-evolution-api-key"
