generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== AUTH ====================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("member")
  companyId     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts  Account[]
  sessions  Session[]
  companies Company[]
  company   CompanyTenant? @relation("CompanyMembers", fields: [companyId], references: [id])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==================== MULTI-TENANT ====================

model CompanyTenant {
  id        String   @id @default(cuid())
  name      String
  segment   String?
  website   String?
  instagram String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members          User[]           @relation("CompanyMembers")
  whatsappSession  WhatsappSession?
  leads            Lead[]
  conversations    Conversation[]
  aiSettings       AiSettings?
  companyProfile   CompanyProfile?
  calendarConfig   CalendarConfig?
  pipelineStages   PipelineStage[]
  meetings         Meeting[]
  activityLogs     ActivityLog[]
}

// ==================== WHATSAPP ====================

model WhatsappSession {
  id          String   @id @default(cuid())
  companyId   String   @unique
  status      WhatsappStatus @default(DISCONNECTED)
  qrCode      String?  @db.Text
  phoneNumber String?
  sessionData Json?
  lastSeen    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company CompanyTenant @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

enum WhatsappStatus {
  DISCONNECTED
  WAITING_QR
  CONNECTED
  ERROR
  RECONNECTING
}

// ==================== LEADS & CRM ====================

model Lead {
  id            String   @id @default(cuid())
  companyId     String
  name          String?
  phone         String
  whatsapp      String?
  email         String?
  company       String?
  origin        String?
  status        String   @default("novo_lead")
  score         Int      @default(0)
  classification LeadClassification @default(COLD)
  interest      String?
  lastMessage   String?
  notes         String?  @db.Text
  nextAction    String?
  meetingDate   DateTime?
  assignedTo    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  companyTenant CompanyTenant  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  conversations Conversation[]
  scores        LeadScore[]
  meetings      Meeting[]

  @@index([companyId])
  @@index([phone])
  @@index([status])
}

enum LeadClassification {
  COLD
  WARM
  HOT
}

model LeadScore {
  id        String   @id @default(cuid())
  leadId    String
  criteria  String
  value     Int
  reason    String?
  createdAt DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
}

model PipelineStage {
  id        String   @id @default(cuid())
  companyId String
  name      String
  order     Int
  color     String?
  createdAt DateTime @default(now())

  company CompanyTenant @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

// ==================== CONVERSATIONS ====================

model Conversation {
  id         String   @id @default(cuid())
  companyId  String
  leadId     String
  status     ConversationStatus @default(ACTIVE)
  startedAt  DateTime @default(now())
  endedAt    DateTime?
  summary    String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  company  CompanyTenant @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lead     Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([companyId])
  @@index([leadId])
}

enum ConversationStatus {
  ACTIVE
  PAUSED
  COMPLETED
  HANDOFF
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  role           MessageRole
  content        String   @db.Text
  metadata       Json?
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

// ==================== AI SETTINGS ====================

model AiSettings {
  id                   String   @id @default(cuid())
  companyId            String   @unique
  aiName               String   @default("Assistente")
  tone                 String   @default("Consultivo, profissional e objetivo")
  segment              String?
  products             String?  @db.Text
  question1            String   @default("Qual é o principal objetivo que você deseja resolver agora?")
  question2            String   @default("Qual é a urgência para resolver isso?")
  question3            String   @default("Você já possui orçamento definido ou está avaliando possibilidades?")
  qualificationCriteria String? @db.Text
  initialMessage       String?  @db.Text
  rules                String?  @db.Text
  canTalkPrice         String   @default("no")
  businessHours        String?
  meetingLink          String?
  humanResponsible     String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  company CompanyTenant @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

// ==================== COMPANY PROFILE ====================

model CompanyProfile {
  id                    String   @id @default(cuid())
  companyId             String   @unique
  description           String?  @db.Text
  history               String?  @db.Text
  mission               String?
  vision                String?
  values                String?
  services              String?  @db.Text
  serviceDetails        String?  @db.Text
  targetAudience        String?  @db.Text
  serviceRegion         String?
  differentials         String?  @db.Text
  painPoints            String?  @db.Text
  benefits              String?  @db.Text
  commonObjections      String?  @db.Text
  objectionAnswers      String?  @db.Text
  faq                   String?  @db.Text
  pricingPolicy         String?  @db.Text
  averageTicket         String?
  paymentMethods        String?
  businessHours         String?
  commercialRules       String?  @db.Text
  allowedTopics         String?  @db.Text
  forbiddenTopics       String?  @db.Text
  humanHandoffRules     String?  @db.Text
  website               String?
  instagram             String?
  catalogUrl            String?
  supportMaterials      String?  @db.Text
  profileCompletionScore Int     @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  company CompanyTenant @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

// ==================== SCHEDULING ====================

model CalendarConfig {
  id              String   @id @default(cuid())
  companyId       String   @unique
  availableDays   String[] @default(["seg", "ter", "qua", "qui", "sex"])
  startTime       String   @default("09:00")
  endTime         String   @default("18:00")
  meetingDuration Int      @default(30)
  responsible     String?
  blockedSlots    Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company CompanyTenant @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Meeting {
  id          String   @id @default(cuid())
  companyId   String
  leadId      String
  date        DateTime
  duration    Int      @default(30)
  status      MeetingStatus @default(SCHEDULED)
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company CompanyTenant @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lead    Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([leadId])
}

enum MeetingStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

// ==================== ACTIVITY LOG ====================

model ActivityLog {
  id        String   @id @default(cuid())
  companyId String
  type      String
  message   String
  metadata  Json?
  createdAt DateTime @default(now())

  company CompanyTenant @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

// ==================== INTEL (existing) ====================

model Company {
  id        String   @id @default(cuid())
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name        String
  industry    String
  segment     String?
  website     String?
  foundedYear Int?
  teamSize    String?
  location    String?

  mission       String?  @db.Text
  vision        String?  @db.Text
  purpose       String?  @db.Text
  values        String[] @default([])
  differentials String[] @default([])

  targetAudience  String?  @db.Text
  mainCompetitors String[] @default([])
  marketPosition  String?  @db.Text
  priceRange      String?

  brandTone       String[] @default([])
  brandKeywords   String[] @default([])
  inspirations    String[] @default([])
  avoidWords      String[] @default([])

  currentProblems String?  @db.Text
  goals           String?  @db.Text
  timeline        String?

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  brandReports  BrandReport[]
  marketReports MarketReport[]

  @@index([userId])
}

model BrandReport {
  id        String   @id @default(cuid())
  companyId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  status    ReportStatus @default(GENERATING)

  brandArchetype    Json?
  brandPositioning  Json?
  brandVoice        Json?
  brandStory        Json?
  visualIdentity    Json?
  brandPurpose      Json?
  competitorAnalysis Json?
  brandEcosystem    Json?
  actionPlan        Json?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model MarketReport {
  id        String   @id @default(cuid())
  companyId String
  createdAt DateTime @default(now())
  status    ReportStatus @default(GENERATING)
  data      Json?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

enum ReportStatus {
  GENERATING
  COMPLETED
  FAILED
}
